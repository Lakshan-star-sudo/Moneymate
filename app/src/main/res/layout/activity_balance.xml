<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Group Balances"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#00C853"
            app:cardCornerRadius="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overall Status"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You owe Rs.500"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="30sp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nimal owes you   Rs.300"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginTop="20dp"
            android:background="#1E1E1E"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kasun owes you   Rs.200"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginTop="10dp"
            android:background="#1E1E1E"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You owe Amal   Rs.1000"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="15dp"
            android:layout_marginTop="10dp"
            android:background="#1E1E1E"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settle Up"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</ScrollView>